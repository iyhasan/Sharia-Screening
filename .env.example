# Default provider (local | yfinance | sec | combined)
SHARIA_PROVIDER=combined

# Local JSON data path (used when provider=local)
SHARIA_DATA_PATH=./data/example.json

# Supplemental data (used when provider=yfinance or sec)
SHARIA_SUPPLEMENTAL_PATH=./data/sec_supplemental.json

# Segment rules (used for SEC provider)
SHARIA_SEGMENT_RULES_PATH=./data/segment_rules.json

# SEC requires a descriptive User-Agent
SEC_USER_AGENT=Your Name contact@example.com
